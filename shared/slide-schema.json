{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personal-ai-presentation.dev/slide-schema.json",
  "title": "Slide Presentation Schema",
  "description": "JSON Schema for Personal AI Presentation slides. Single source of truth for both frontend TypeScript types and backend Pydantic models.",
  "definitions": {
    "SlideLayout": {
      "type": "string",
      "enum": ["title", "two-column", "highlight-number", "table", "bullet-list"],
      "description": "The visual layout template for this slide"
    },
    "ContentBlock": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["paragraph", "heading", "image", "list"],
          "description": "Type of content in this block"
        },
        "text": { "type": "string" },
        "level": { "type": "integer", "minimum": 1, "maximum": 3 },
        "imageUrl": { "type": "string", "format": "uri" },
        "imageAlt": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["type"]
    },
    "Slide": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique slide identifier" },
        "layout": { "$ref": "#/definitions/SlideLayout" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "body": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "columns": {
          "type": "object",
          "properties": {
            "left": {
              "type": "array",
              "items": { "$ref": "#/definitions/ContentBlock" }
            },
            "right": {
              "type": "array",
              "items": { "$ref": "#/definitions/ContentBlock" }
            }
          },
          "required": ["left", "right"]
        },
        "highlightNumber": {
          "type": "object",
          "properties": {
            "value": { "type": "string" },
            "label": { "type": "string" },
            "suffix": { "type": "string" }
          },
          "required": ["value", "label"]
        },
        "table": {
          "type": "object",
          "properties": {
            "headers": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rows": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "required": ["headers", "rows"]
        },
        "background": {
          "type": "object",
          "properties": {
            "color": { "type": "string" },
            "imageUrl": { "type": "string", "format": "uri" }
          }
        },
        "notes": { "type": "string" }
      },
      "required": ["id", "layout"]
    },
    "Presentation": {
      "type": "object",
      "properties": {
        "metadata": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "author": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" },
            "slideCount": { "type": "integer" }
          },
          "required": ["title", "createdAt"]
        },
        "slides": {
          "type": "array",
          "items": { "$ref": "#/definitions/Slide" },
          "minItems": 1
        }
      },
      "required": ["metadata", "slides"]
    }
  }
}
