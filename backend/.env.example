# ============================================================
# Personal AI Presentation — Phase 3 SaaS Backend Configuration
# ============================================================

# Server
DEBUG=true
PORT=8000
CORS_ORIGINS=http://localhost:3000

# Database (SQLite for dev, Postgres for production)
DATABASE_URL=sqlite+aiosqlite:///./data.db

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-random-64-character-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ============================================================
# LLM Provider — 支持任意 OpenAI 兼容端点
#
# 方式 1: DeepSeek 官方 (推荐，国内最快)
#   LLM_API_BASE=https://api.deepseek.com/v1
#   LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_MODEL_NAME=deepseek-chat
#
# 方式 2: 硅基流动 (SiliconFlow)
#   LLM_API_BASE=https://api.siliconflow.cn/v1
#   LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_MODEL_NAME=deepseek-ai/DeepSeek-V3
#
# 方式 3: OpenAI 官方
#   LLM_API_BASE=https://api.openai.com/v1
#   LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_MODEL_NAME=gpt-4o
#
# 方式 4: 智谱 AI (GLM)
#   LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
#   LLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxx
#   LLM_MODEL_NAME=glm-4-flash
#
# 方式 5: 本地 Ollama
#   LLM_API_BASE=http://localhost:11434/v1
#   LLM_API_KEY=ollama
#   LLM_MODEL_NAME=qwen2.5:7b
# ============================================================
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-deepseek-api-key-here
LLM_MODEL_NAME=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Image Generation (optional)
IMAGE_PROVIDER=none
IMAGE_API_ENDPOINT=
IMAGE_API_KEY=
IMAGE_MODEL=dall-e-3

# Rate Limiting & User Tiers
RATE_LIMIT_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
FREE_GENERATIONS_PER_HOUR=3
FREE_GENERATIONS_PER_DAY=10
FREE_EXPORT_PER_HOUR=5
PREMIUM_GENERATIONS_PER_HOUR=60
PREMIUM_GENERATIONS_PER_DAY=480

# Payment Gateway
PAYMENT_WEBHOOK_SECRET=change-me-to-a-random-secret
PAYMENT_MERCHANT_ID=your-merchant-id
PAYMENT_GATEWAY_URL=https://pay.example.com
PAYMENT_RETURN_URL=http://localhost:3000
PAYMENT_SANDBOX_MODE=true

# Async Task Queue
MAX_CONCURRENT_TASKS=4
TASK_TIMEOUT_SECONDS=300

# Data Privacy
AUTO_PURGE_HOURS=24
TASK_CLEANUP_HOURS=1
